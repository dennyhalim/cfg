RewriteEngine On

# Block requests whose User-Agent doesn't match Firefox or FxiOS
RewriteCond %{HTTP_USER_AGENT} !Firefox [NC]
RewriteCond %{HTTP_USER_AGENT} !FxiOS   [NC]
RewriteRule ^ - [F,L]

RewriteCond %{HTTP_USER_AGENT} (bot|crawl|spider|slurp|scraper) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (AhrefsBot|SemrushBot|DotBot|MJ12bot|BLEXBot) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (PetalBot|DataForSeoBot|serpstatbot|Bytespider) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (ClaudeBot|GPTBot|CCBot) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (FacebookExternalHit|Twitterbot|facebookcatalog|LinkedInBot) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (Applebot|YandexBot|Baiduspider) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (HeadlessChrome|PhantomJS|Puppeteer|Playwright) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (python-requests|python-urllib|curl|wget|libwww-perl) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (Go-http-client|Java|okhttp) [NC]
RewriteRule ^ - [F,L]
